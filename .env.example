INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_API_VERSION=v19.0
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

IMAGE_GENERATION_PROVIDER=antigravity
CODEX_OUTPUT_DIR=
CODEX_IMAGE_WAIT_SECONDS=0

# Antigravity CLI bridge.
# If the CLI accepts stdin and returns stdout, use a command without placeholders.
# If the CLI needs files, use placeholders: {prompt_file}, {output_file}, {mode}.
ANTIGRAVITY_ENABLED=true
ANTIGRAVITY_TEXT_COMMAND=antigravity run --stdin
ANTIGRAVITY_IMAGE_COMMAND=
ANTIGRAVITY_TIMEOUT_SECONDS=300
ANTIGRAVITY_IMAGE_TIMEOUT_SECONDS=300

PUBLIC_BASE_URL=
IMGUR_CLIENT_ID=
PEXELS_API_KEY=
PIXABAY_API_KEY=

PORT=3001
VIDEO_ORIENTATION=landscape
VIDEO_VOICE=ko-KR-SunHiNeural

TELEGRAM_BOT_NAME=MindFactoryBot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_COMMANDS_ENABLED=true
