<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.mindfactory.dashboard</string>
  <key>ProgramArguments</key>
  <array>
    <string>/path/to/SNS_Automatic_System/scripts/run_dashboard.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/path/to/SNS_Automatic_System</string>
  <key>StandardOutPath</key>
  <string>/path/to/SNS_Automatic_System/agent_runs/dashboard_server.log</string>
  <key>StandardErrorPath</key>
  <string>/path/to/SNS_Automatic_System/agent_runs/dashboard_server.err.log</string>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
